<odoo>
    <record id="view_sale_order_form_inherit_brand_category" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.brand.category</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="before">
                <field name="category_id" widget="many2one" width="100%"/>
                <field name="brand_id" widget="many2one" width="100%"/>
            </xpath>

            <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="attributes">
                <attribute name="domain">
                    [('sale_ok', '=', True), ('categ_id', '=', category_id)]
                </attribute>
            </xpath>

        </field>
    </record>


    <record id="view_pricelist_form_inherit_partner" model="ir.ui.view">
        <field name="name">product.pricelist.form.inherit.partner</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='company_id']" position="after">
                <field name="partner_id"/>
            </xpath>

        </field>
    </record>


</odoo>